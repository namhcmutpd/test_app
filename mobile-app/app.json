{
  "expo": {
    "name": "HealthGuard",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Ứng dụng cần Bluetooth để kết nối thiết bị đeo và cập nhật dữ liệu sức khỏe theo thời gian thực.",
        "NSBluetoothPeripheralUsageDescription": "Ứng dụng cần Bluetooth để đồng bộ dữ liệu từ thiết bị đeo.",
        "NSHealthShareUsageDescription": "Ứng dụng cần truy cập dữ liệu sức khỏe để hiển thị nhịp tim, bước chân và giấc ngủ.",
        "NSHealthUpdateUsageDescription": "Ứng dụng cần ghi dữ liệu sức khỏe từ thiết bị đeo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ],
      "package": "com.namhu147.mobileapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true
        }
      ],
      [
        "react-native-health-connect",
        {
          "permissions": [
            "android.permission.health.READ_HEART_RATE",
            "android.permission.health.READ_STEPS",
            "android.permission.health.READ_DISTANCE",
            "android.permission.health.READ_SLEEP",
            "android.permission.health.READ_OXYGEN_SATURATION",
            "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "88e77407-7bb6-476d-a969-60c1b886e6cc"
      }
    }
  }
}
