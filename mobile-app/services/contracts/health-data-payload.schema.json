{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthguard.local/schemas/health-data-payload.schema.json",
  "title": "HealthDataPayload",
  "description": "Payload sync metrics from mobile device to backend",
  "type": "object",
  "additionalProperties": false,
  "required": ["user_id", "device_id", "metrics"],
  "properties": {
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["record_time"],
        "properties": {
          "record_time": {
            "type": "string",
            "format": "date-time"
          },
          "heart_rate": {
            "type": "integer",
            "minimum": 0,
            "maximum": 260
          },
          "steps": {
            "type": "integer",
            "minimum": 0
          },
          "sleep_duration": {
            "type": "integer",
            "minimum": 0,
            "description": "Sleep duration in minutes"
          },
          "stress_level": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        },
        "anyOf": [
          { "required": ["heart_rate"] },
          { "required": ["steps"] },
          { "required": ["sleep_duration"] },
          { "required": ["stress_level"] }
        ]
      }
    }
  }
}
